{"metadata":{"externalID":"c:@F@samSelectDetailRegion","symbolKind":"func","role":"symbol","roleHeading":"Function","modules":[{"name":"DotDocument"}],"navigatorTitle":[{"kind":"identifier","text":"samSelectDetailRegion"}],"fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"title":"samSelectDetailRegion"},"hierarchy":{"paths":[["doc:\/\/DotDocument\/documentation\/DotDocument"]]},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotdocument\/samselectdetailregion"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/DotDocument\/documentation\/DotDocument\/samSelectDetailRegion","interfaceLanguage":"occ"},"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"preciseIdentifier":"c:I","text":"int","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"samSelectDetailRegion","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"keyword","text":"const"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/DotDocument\/documentation\/DotDocument\/sam_color_image","preciseIdentifier":"c:@S@sam_color_image","text":"SamColorImage","kind":"typeIdentifier"},{"text":" * ","kind":"text"},{"text":"image","kind":"internalParam"},{"text":", ","kind":"text"},{"text":"const","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:I","text":"int"},{"kind":"text","text":" * "},{"text":"detectedObjectBoundingBox","kind":"internalParam"},{"text":", ","kind":"text"},{"text":"int","kind":"typeIdentifier","preciseIdentifier":"c:I"},{"text":" * ","kind":"text"},{"text":"selectedBoundingBox","kind":"internalParam"},{"text":");","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"return-value","type":"heading","text":"Return Value"},{"inlineContent":[{"text":"0 on success, or a non-zero error code on failure.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Analyzes the input image and identifies the most suitable 200x200 pixel","type":"text"},{"type":"text","text":" "},{"type":"text","text":"region (bounding box) with high level of details that intersects a given bounding box."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"text":" is empty (width or height is 0), any region can be selected. Otherwise,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the selected region should have non-empty intersection with this bounding box. The selected region"},{"text":" ","type":"text"},{"text":"should lie fully inside the input image.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}]},{"syntax":null,"type":"codeListing","code":["                                  a bounding box in the format (x, y, width, height)."]},{"syntax":null,"type":"codeListing","code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."]}]}],"references":{"doc://DotDocument/documentation/DotDocument":{"identifier":"doc:\/\/DotDocument\/documentation\/DotDocument","role":"collection","kind":"symbol","abstract":[{"type":"text","text":"version: 9.3.0"}],"type":"topic","url":"\/documentation\/dotdocument","title":"DotDocument"},"doc://DotDocument/documentation/DotDocument/samSelectDetailRegion":{"abstract":[],"type":"topic","url":"\/documentation\/dotdocument\/samselectdet