00x200 pixel","type":"text"},{"text":" ","type":"text"},{"text":"region (bounding box) with high level of details that intersects a given bounding box.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"text":" is empty (width or height is 0), any region can be selected. Otherwise,","type":"text"},{"text":" ","type":"text"},{"text":"the selected region should have non-empty intersection with this bounding box. The selected region","type":"text"},{"text":" ","type":"text"},{"text":"should lie fully inside the input image.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If there is no region satisfying these conditions - if image width or height is smaller than 200","type":"text"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200).","type":"text"}]},{"syntax":null,"type":"codeListing","code":["                                  a bounding box in the format (x, y, width, height)."]},{"syntax":null,"type":"codeListing","code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotdocument\/samselectdetailregion"]}],"kind":"symbol","references":{"doc://DotDocument/documentation/DotDocument":{"type":"topic","role":"collection","identifier":"doc:\/\/DotDocument\/documentation\/DotDocument","kind":"symbol","url":"\/documentation\/dotdocument","title":"DotDocument","abstract":[{"type":"text","text":"version: 9.2.1"}]},"doc://DotDocument/documentation/DotDocument/sam_color_image":{"identifier":"doc:\/\/DotDocument\/documentation\/DotDocument\/sam_color_image","fra