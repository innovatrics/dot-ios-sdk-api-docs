,{"type":"paragraph","inlineContent":[{"text":"Region (bounding box) with high level of details that intersects a given bounding box.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"text":" is empty (width or height is 0), any region can be selected. Otherwise,","type":"text"},{"text":" ","type":"text"},{"text":"the selected region should have non-empty intersection with this bounding box. The selected region","type":"text"},{"text":" ","type":"text"},{"text":"should lie fully inside the input image.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}]},{"type":"codeListing","syntax":null,"code":["                                   a bounding box in the format (x, y, width, height)."]},{"type":"codeListing","syntax":null,"code":["                                   return, contains the bounding box in the format (x, y, width, height),","                                   where width and height are always set to 200."]}]}],"hierarchy":{"paths":[["doc:\/\/DotDocument\/documentation\/DotDocument"]]},"references":{"doc://DotDocument/documentation/DotDocument/samSelectDetailRegion":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/DotDocument\/documentation\/DotDocument\/samSelectDetailRegion","fragments":[{"kind":"identifier","text":"samSelectDetailRegion"}],"type":"topic","title":"samSelectDetailRegion","abstract":[],"url":"\/documentation\/dotdocument\/samselectdetailregion"},"doc://DotDocument/documentation/DotDocument/sam_color_image":{"type":"topic","title":"sam_color_image","identifier":"doc:\/\/DotDocument\/documentation\/DotDocument\