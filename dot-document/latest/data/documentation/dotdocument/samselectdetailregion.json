ing box) with high level of details that intersects a given bounding box.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"text":" is empty (width or height is 0), any region can be selected. Otherwise,","type":"text"},{"text":" ","type":"text"},{"text":"the selected region should have non-empty intersection with this bounding box. The selected region","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"should lie fully inside the input image."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"type":"text","text":"or "},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}]},{"type":"codeListing","syntax":null,"code":["                                  a bounding box in the format (x, y, width, height)."]},{"type":"codeListing","syntax":null,"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."]}]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/DotDocument\/documentation\/DotDocument"]]},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/DotDocument\/documentation\/DotDocument\/samSelectDetailRegion"},"references":{"doc://DotDocument/documentation/DotDocument/samSelectDetailRegion":{"type":"topic","role":"symbol","abstract":[],"kind":"symbol","identifier":"doc:\/\/DotDocument\/documentation\/DotDocument\/samSelectDetailRegion","url":"\/documentation\/dotdocument\/samselectdetailregion","title":"samSelectDetailRegion","fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}]},"doc://DotDocument/documentation/DotDocument/