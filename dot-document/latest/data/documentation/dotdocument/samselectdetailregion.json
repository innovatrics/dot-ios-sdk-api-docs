elected region should have non-empty intersection with this bounding box. The selected region","type":"text"},{"text":" ","type":"text"},{"text":"should lie fully inside the input image.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If there is no region satisfying these conditions - if image width or height is smaller than 200","type":"text"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200).","type":"text"}],"type":"paragraph"},{"code":["                                  a bounding box in the format (x, y, width, height)."],"syntax":null,"type":"codeListing"},{"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."],"syntax":null,"type":"codeListing"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/dotdocument\/samselectdetailregion"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"kind":"symbol","metadata":{"symbolKind":"func","navigatorTitle":[{"kind":"identifier","text":"samSelectDetailRegion"}],"modules":[{"name":"DotDocument"}],"externalID":"c:@F@samSelectDetailRegion","role":"symbol","fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"title":"samSelectDetailRegion","roleHeading":"Function"},"hierarchy":{"paths":[["doc:\/\/DotDocument\/documentation\/DotDocument"]]},"references":{"doc://DotDocument/documentation/DotDocument/samSelectDetailRegion":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/DotDocument\/documentation\/DotDocument\/samSelectDetailRegion","title":"samSelectDetailRegion","abstract":[],"fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"url":"\/documentation\/dotdocument\/samselectdetailregion","type":"topic"},"doc://DotDocument/documentation/DotDocument"