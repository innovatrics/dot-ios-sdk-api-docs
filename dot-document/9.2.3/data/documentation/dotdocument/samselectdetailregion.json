text":" ","type":"text"},{"text":"region (bounding box) with high level of details that intersects a given bounding box.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"text":" is empty (width or height is 0), any region can be selected. Otherwise,","type":"text"},{"text":" ","type":"text"},{"text":"the selected region should have non-empty intersection with this bounding box. The selected region","type":"text"},{"type":"text","text":" "},{"text":"should lie fully inside the input image.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If there is no region satisfying these conditions - if image width or height is smaller than 200","type":"text"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}]},{"type":"codeListing","code":["                                  a bounding box in the format (x, y, width, height)."],"syntax":null},{"syntax":null,"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/DotDocument\/documentation\/DotDocument"]]},"identifier":{"url":"doc:\/\/DotDocument\/documentation\/DotDocument\/samSelectDetailRegion","interfaceLanguage":"occ"},"references":{"doc://DotDocument/documentation/DotDocument/sam_color_image":{"abstract":[],"fragments":[{"text":"sam_color_image","kind":"identifier"}],"identifier":"doc:\/\/DotDocument\/documentation\/DotDocument\/sam_color_image","type":"topic","url":"\/documentation\/dotdocument\/sam_color_image","title":"sam_color_image","kind":"symbol","role":"symbol"},"doc://DotDocument/documentation/DotDocument/samSelectDetailRegion":{"abstr