ted. Otherwise,"},{"type":"text","text":" "},{"type":"text","text":"the selected region should have non-empty intersection with this bounding box. The selected region"},{"type":"text","text":" "},{"type":"text","text":"should lie fully inside the input image."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["                                  a bounding box in the format (x, y, width, height)."]},{"syntax":null,"type":"codeListing","code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."]}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotdocument\/samselectdetailregion"]}],"sections":[],"metadata":{"modules":[{"name":"DotDocument"}],"navigatorTitle":[{"text":"samSelectDetailRegion","kind":"identifier"}],"symbolKind":"func","roleHeading":"Function","externalID":"c:@F@samSelectDetailRegion","title":"samSelectDetailRegion","role":"symbol","fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}]},"references":{"doc://DotDocument/documentation/DotDocument/samSelectDetailRegion":{"fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"identifier":"doc:\/\/DotDocument\/documentation\/DotDocument\/samSelectDetailRegion","role":"symbol","kind":"symbol","url":"\/documentation\/dotdocument\/samselectdetailregion","type":"topic","abstract":[],"title":"samSelectDetailRegion"},"doc://DotDocument/documentation/DotDocument"