,"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" is empty (width or height is 0), any region can be selected. Otherwise,"},{"type":"text","text":" "},{"type":"text","text":"the selected region should have non-empty intersection with this bounding box. The selected region"},{"type":"text","text":" "},{"type":"text","text":"should lie fully inside the input image."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}]},{"type":"codeListing","syntax":null,"code":["                                  a bounding box in the format (x, y, width, height)."]},{"type":"codeListing","syntax":null,"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/DotFaceCore\/documentation\/DotFaceCore"]]},"variants":[{"paths":["\/documentation\/dotfacecore\/samselectdetailregion"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore\/samSelectDetailRegion"},"references":{"doc://DotFaceCore/documentation/DotFaceCore/samSelectDetailRegion":{"role":"symbol","url":"\/documentation\/dotfacecore\/samselectdetailregion","kind":"symbol","abstract":[],"title":"samSelectDetailRegion","fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore\/samSelectDetailRegion"},"doc://DotFaceCore/documentation/DotFaceCore"