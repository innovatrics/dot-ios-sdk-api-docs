 pixel"},{"type":"text","text":" "},{"type":"text","text":"region (bounding box) with high level of details that intersects a given bounding box."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" is empty (width or height is 0), any region can be selected. Otherwise,"},{"type":"text","text":" "},{"type":"text","text":"the selected region should have non-empty intersection with this bounding box. The selected region"},{"type":"text","text":" "},{"type":"text","text":"should lie fully inside the input image."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}],"type":"paragraph"},{"syntax":null,"code":["                                  a bounding box in the format (x, y, width, height)."],"type":"codeListing"},{"syntax":null,"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."],"type":"codeListing"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotfacecore\/samselectdetailregion"]}],"references":{"doc://DotFaceCore/documentation/DotFaceCore/sam_color_image":{"fragments":[{"text":"sam_color_image","kind":"identifier"}],"title":"sam_color_image","type":"topic","role":"symbol","url":"\/documentation\/dotfacecore\/sam_color_image","identifier":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore\/sam_color_image","abstract":[],"kind":"symbol"},"doc://DotFaceCore/documentation/DotFaceCore":{"url":"\/documentation\/dotf