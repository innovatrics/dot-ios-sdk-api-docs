:" ","type":"text"},{"text":"region (bounding box) with high level of details that intersects a given bounding box.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" is empty (width or height is 0), any region can be selected. Otherwise,"},{"type":"text","text":" "},{"type":"text","text":"the selected region should have non-empty intersection with this bounding box. The selected region"},{"type":"text","text":" "},{"type":"text","text":"should lie fully inside the input image."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If there is no region satisfying these conditions - if image width or height is smaller than 200","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or "},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200).","type":"text"}]},{"code":["                                  a bounding box in the format (x, y, width, height)."],"type":"codeListing","syntax":null},{"syntax":null,"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."],"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotfacecore\/samselectdetailregion"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","references":{"doc://DotFaceCore/documentation/DotFaceCore":{"kind":"symbol","url":"\/documentation\/dotfacecore","identifier":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore","abstract":[{"type":"text","text":"version: 9.2.2"}],"role":"collection","title":"DotFaceCore","type":"topic"},"doc://DotFaceCore/documentation/DotFaceCore/sam_color_image":{"title":"sam_color_image","url":"\/documentation\/dotfacecore\/sam_color_image","abs