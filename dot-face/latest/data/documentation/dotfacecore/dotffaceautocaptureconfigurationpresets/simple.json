{"sections":[],"abstract":[{"text":"Configuration suitable for face verification use cases.","type":"text"},{"text":" ","type":"text"},{"text":"The component operates without any visual aids or guidance for the user, with the exception of the detection layer (tracking circle).","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"There is no automatic triggering of the capture process."},{"type":"text","text":" "},{"type":"text","text":"Instead, the client is responsible for initiating the capture by explicitly calling the "},{"text":"requestCapture","type":"text"},{"text":" method.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This configuration provides a minimalistic approach, offering flexibility to the client in managing the capture timing and user interaction,"},{"type":"text","text":" "},{"type":"text","text":"which is often desired in verification scenarios."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotfacecore\/dotffaceautocaptureconfigurationpresets\/simple"]}],"hierarchy":{"paths":[["doc:\/\/DotFaceCore\/documentation\/DotFaceCore","doc:\/\/DotFaceCore\/documentation\/DotFaceCore\/DOTFFaceAutoCaptureConfigurationPresets"]]},"kind":"symbol","metadata":{"navigatorTitle":[{"text":"simple","kind":"identifier"}],"fragments":[{"kind":"identifier","text":"simple"}],"roleHeading":"Type Property","title":"simple","externalID":"c:@M@DotFaceCore@objc(cs)DOTFFaceAutoCaptureConfigurationPresets(cpy)simple","modules":[{"name":"DotFaceCore"}],"role":"symbol","symbolKind":"property"},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore\/DOTFFaceAutoCaptureConfigurationPresets\/simple","interfaceLanguage":"occ"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["occ"],"tokens":[{"kind":"keyword","text":"@property"},{"kind":"text","text":" ("},{"kind":"keyword","text":"class"},{"kind":"text","text":", "},{"kind