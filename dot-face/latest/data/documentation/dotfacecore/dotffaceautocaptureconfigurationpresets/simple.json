triggering of the capture process."},{"type":"text","text":" "},{"type":"text","text":"Instead, the client is responsible for initiating the capture by explicitly calling the "},{"type":"text","text":"requestCapture"},{"type":"text","text":" method."},{"type":"text","text":" "},{"type":"text","text":"This configuration provides a minimalistic approach, offering flexibility to the client in managing the capture timing and user interaction,"},{"type":"text","text":" "},{"type":"text","text":"which is often desired in verification scenarios."}],"type":"topic","role":"symbol","kind":"symbol","title":"simple","fragments":[{"kind":"identifier","text":"simple"}]},"doc://DotFaceCore/documentation/DotFaceCore/DOTFFaceAutoCaptureConfigurationPresets":{"title":"DOTFFaceAutoCaptureConfigurationPresets","role":"symbol","type":"topic","identifier":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore\/DOTFFaceAutoCaptureConfigurationPresets","abstract":[{"type":"text","text":"Pre-defined sets of configurations."}],"url":"\/documentation\/dotfacecore\/dotffaceautocaptureconfigurationpresets","kind":"symbol","fragments":[{"text":"DOTFFaceAutoCaptureConfigurationPresets","kind":"identifier"}]}}}