":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"text":" is empty (width or height is 0), any region can be selected. Otherwise,","type":"text"},{"text":" ","type":"text"},{"text":"the selected region should have non-empty intersection with this bounding box. The selected region","type":"text"},{"text":" ","type":"text"},{"text":"should lie fully inside the input image.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If there is no region satisfying these conditions - if image width or height is smaller than 200","type":"text"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200).","type":"text"}],"type":"paragraph"},{"code":["                                   a bounding box in the format (x, y, width, height)."],"syntax":null,"type":"codeListing"},{"code":["                                   return, contains the bounding box in the format (x, y, width, height),","                                   where width and height are always set to 200."],"syntax":null,"type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotfacecore\/samselectdetailregion"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"symbol","references":{"doc://DotFaceCore/documentation/DotFaceCore":{"url":"\/documentation\/dotfacecore","role":"collection","abstract":[{"text":"version: 9.2.0","type":"text"}],"identifier":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore","title":"DotFaceCore","kind":"symbol","type":"topic"},"doc://DotFaceCore/documentation/DotFaceCore/samSelectDetailRegion":{"url":"\/documentation\/dotfacecore\/samselectdetailregion","title":"samSelectDetailRegion","role":"symbol","fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"identifier":"doc:\/\/Do