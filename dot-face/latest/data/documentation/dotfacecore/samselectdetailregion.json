{"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/DotFaceCore\/documentation\/DotFaceCore"]]},"metadata":{"modules":[{"name":"DotFaceCore"}],"role":"symbol","fragments":[{"kind":"identifier","text":"samSelectDetailRegion"}],"symbolKind":"func","roleHeading":"Function","title":"samSelectDetailRegion","externalID":"c:@F@samSelectDetailRegion","navigatorTitle":[{"text":"samSelectDetailRegion","kind":"identifier"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"preciseIdentifier":"c:I","kind":"typeIdentifier","text":"int"},{"kind":"text","text":" "},{"kind":"identifier","text":"samSelectDetailRegion"},{"kind":"text","text":"("},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"preciseIdentifier":"c:@S@sam_color_image","kind":"typeIdentifier","identifier":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore\/sam_color_image","text":"SamColorImage"},{"kind":"text","text":" * "},{"kind":"internalParam","text":"image"},{"kind":"text","text":", "},{"kind":"keyword","text":"const"},{"kind":"text","text":" "},{"preciseIdentifier":"c:I","kind":"typeIdentifier","text":"int"},{"kind":"text","text":" * "},{"kind":"internalParam","text":"detectedObjectBoundingBox"},{"kind":"text","text":", "},{"preciseIdentifier":"c:I","kind":"typeIdentifier","text":"int"},{"kind":"text","text":" * "},{"kind":"internalParam","text":"selectedBoundingBox"},{"kind":"text","text":");"}]}]},{"content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"0 on success, or a non-zero error code on failure."}]}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Analyzes the input image and identifies the most suitable 200x200 pixel"},{"type":"text","text":" "},{"type":"text","text":"region (bounding box) with high level of details that intersects a given bounding box."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" is empty (width or height is 0), any region can be selected. Otherwise,"},{"type":"text","text":" "},{"type":"text","text":"the selected region should have non-empty intersection with this bounding box. The selected region"},{"type":"text","text":" "},{"type":"text","text":"should lie fully inside the input image."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}]},{"type":"codeListing","syntax":null,"code":["                                  a bounding box in the format (x, y, width, height)."]},{"type":"codeListing","syntax":null,"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/dotfacecore\/samselectdetailregion"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore\/samSelectDetailRegion","interfaceLanguage":"occ"},"references":{"doc://DotFaceCore/documentation/DotFaceCore":{"identifier":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore","type":"topic","abstract":[{"text":"version: 9.2.3","type":"text"}],"kind":"symbol","role":"collection","title":"DotFaceCore","url":"\/documentation\/dotfacecore"},"doc://DotFaceCore/documentation/DotFaceCore/sam_color_image":{"identifier":"doc:\/\/DotFaceCore\/documentation\/DotFaceCore\/sam_color_image","kin