ion should have non-empty intersection with this bounding box. The selected region"},{"type":"text","text":" "},{"type":"text","text":"should lie fully inside the input image."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"type":"text","text":"or "},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}]},{"type":"codeListing","syntax":null,"code":["                                  a bounding box in the format (x, y, width, height)."]},{"type":"codeListing","syntax":null,"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."]}]}],"kind":"symbol","metadata":{"externalID":"c:@F@samSelectDetailRegion","roleHeading":"Function","modules":[{"name":"DotFaceLite"}],"fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"samSelectDetailRegion"}],"symbolKind":"func","role":"symbol","title":"samSelectDetailRegion"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/samSelectDetailRegion"},"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotfacelite\/samselectdetailregion"]}],"references":{"doc://DotFaceLite/documentation/DotFaceLite/samSelectDetailRegion":{"role":"symbol","type":"topic","fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/dotfacelite\/samselectdetailregion","identifier":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/samSelectDetailRegion","abstract":[],"title":"samSelectDetailRegion"},"doc://DotFaceLite/documentation/DotFaceLite/