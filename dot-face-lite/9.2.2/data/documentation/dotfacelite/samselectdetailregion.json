e":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"text":" is empty (width or height is 0), any region can be selected. Otherwise,","type":"text"},{"text":" ","type":"text"},{"text":"the selected region should have non-empty intersection with this bounding box. The selected region","type":"text"},{"text":" ","type":"text"},{"text":"should lie fully inside the input image.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If there is no region satisfying these conditions - if image width or height is smaller than 200","type":"text"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200).","type":"text"}]},{"type":"codeListing","syntax":null,"code":["                                  a bounding box in the format (x, y, width, height)."]},{"type":"codeListing","syntax":null,"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."]}],"kind":"content"}],"metadata":{"externalID":"c:@F@samSelectDetailRegion","roleHeading":"Function","modules":[{"name":"DotFaceLite"}],"fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"symbolKind":"func","navigatorTitle":[{"text":"samSelectDetailRegion","kind":"identifier"}],"role":"symbol","title":"samSelectDetailRegion"},"references":{"doc://DotFaceLite/documentation/DotFaceLite/samSelectDetailRegion":{"abstract":[],"kind":"symbol","type":"topic","identifier":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/samSelectDetailRegion","fragments":[{"kind":"identifier","text":"samSelectDetailRegion"}],"title":"samSelectDetailRegion","url":"\/documentation\/dotfacelite\/samselectdetailregion","role":"symbol"},"doc://DotFaceLite/documentation/DotFaceLite/