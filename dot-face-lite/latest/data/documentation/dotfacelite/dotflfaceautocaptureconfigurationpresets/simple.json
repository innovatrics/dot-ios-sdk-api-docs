{"kind":"symbol","abstract":[{"type":"text","text":"Configuration suitable for face verification use cases."},{"type":"text","text":" "},{"type":"text","text":"The component operates without any visual aids or guidance for the user, with the exception of the detection layer (tracking circle)."},{"type":"text","text":" "},{"type":"text","text":"There is no automatic triggering of the capture process."},{"type":"text","text":" "},{"type":"text","text":"Instead, the client is responsible for initiating the capture by explicitly calling the "},{"type":"text","text":"requestCapture"},{"type":"text","text":" method."},{"type":"text","text":" "},{"type":"text","text":"This configuration provides a minimalistic approach, offering flexibility to the client in managing the capture timing and user interaction,"},{"type":"text","text":" "},{"type":"text","text":"which is often desired in verification scenarios."}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotfacelite\/dotflfaceautocaptureconfigurationpresets\/simple"]}],"hierarchy":{"paths":[["doc:\/\/DotFaceLite\/documentation\/DotFaceLite","doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/DOTFLFaceAutoCaptureConfigurationPresets"]]},"metadata":{"modules":[{"name":"DotFaceLite"}],"title":"simple","role":"symbol","externalID":"c:@M@DotFaceLite@objc(cs)DOTFLFaceAutoCaptureConfigurationPresets(cpy)simple","roleHeading":"Type Property","navigatorTitle":[{"kind":"identifier","text":"simple"}],"symbolKind":"property","fragments":[{"text":"simple","kind":"identifier"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["occ"],"tokens":[{"text":"@property","kind":"keyword"},{"text":" (","kind":"text"},{"text":"class","kind":"keyword"},{"text":", ","kind":"text"},{"text":"nonatomic","kind":"keyword"},{"text":", ","kind":"text"},{"text":"strong","kind":"keyword"},{"text":", ","kind":"text"},{"text":"reado