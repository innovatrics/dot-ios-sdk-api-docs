nput image and identifies the most suitable 200x200 pixel","type":"text"},{"text":" ","type":"text"},{"text":"region (bounding box) with high level of details that intersects a given bounding box.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" is empty (width or height is 0), any region can be selected. Otherwise,"},{"type":"text","text":" "},{"text":"the selected region should have non-empty intersection with this bounding box. The selected region","type":"text"},{"text":" ","type":"text"},{"text":"should lie fully inside the input image.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}]},{"syntax":null,"type":"codeListing","code":["                                  a bounding box in the format (x, y, width, height)."]},{"type":"codeListing","syntax":null,"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."]}]}],"variants":[{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/dotfacelite\/samselectdetailregion"]}],"references":{"doc://DotFaceLite/documentation/DotFaceLite/samSelectDetailRegion":{"role":"symbol","kind":"symbol","url":"\/documentation\/dotfacelite\/samselectdetailregion","type":"topic","fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"identifier":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/samSelectDetailRegion","title":"samSelectDetailRegion","abstract":[]},"doc://DotFaceLite/documentation/DotFaceLite"