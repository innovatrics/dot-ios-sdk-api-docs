ent":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Region (bounding box) with high level of details that intersects a given bounding box."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"text":" is empty (width or height is 0), any region can be selected. Otherwise,","type":"text"},{"text":" ","type":"text"},{"text":"the selected region should have non-empty intersection with this bounding box. The selected region","type":"text"},{"text":" ","type":"text"},{"text":"should lie fully inside the input image.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If there is no region satisfying these conditions - if image width or height is smaller than 200","type":"text"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"type":"codeVoice","code":"detectedObjectBoundingBox"},{"text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200).","type":"text"}]},{"type":"codeListing","syntax":null,"code":["                                   a bounding box in the format (x, y, width, height)."]},{"type":"codeListing","syntax":null,"code":["                                   return, contains the bounding box in the format (x, y, width, height),","                                   where width and height are always set to 200."]}]}],"references":{"doc://DotFaceLite/documentation/DotFaceLite/samSelectDetailRegion":{"abstract":[],"fragments":[{"text":"samSelectDetailRegion","kind":"identifier"}],"title":"samSelectDetailRegion","type":"topic","role":"symbol","url":"\/documentation\/dotfacelite\/samselectdetailregion","kind":"symbol","identifier":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/samSelectDetailRegion"},"doc://DotFaceLite/documentation/DotFaceLite":{"type":"topic","identifier":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite","title":"DotFaceLite","abstract":[{"type"