":"Analyzes the input image and identifies the most suitable 200x200 pixel"},{"type":"text","text":" "},{"type":"text","text":"region (bounding box) with high level of details that intersects a given bounding box."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"type":"text","text":" is empty (width or height is 0), any region can be selected. Otherwise,"},{"type":"text","text":" "},{"type":"text","text":"the selected region should have non-empty intersection with this bounding box. The selected region"},{"type":"text","text":" "},{"type":"text","text":"should lie fully inside the input image."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no region satisfying these conditions - if image width or height is smaller than 200"},{"type":"text","text":" "},{"type":"text","text":"or "},{"code":"detectedObjectBoundingBox","type":"codeVoice"},{"type":"text","text":" lies outside the image, the selected bounding box will be (0, 0, 200, 200)."}]},{"code":["                                  a bounding box in the format (x, y, width, height)."],"syntax":null,"type":"codeListing"},{"code":["                                  return, contains the bounding box in the format (x, y, width, height),","                                  where width and height are always set to 200."],"syntax":null,"type":"codeListing"}]}],"identifier":{"interfaceLanguage":"occ","url":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/samSelectDetailRegion"},"sections":[],"references":{"doc://DotFaceLite/documentation/DotFaceLite/sam_color_image":{"abstract":[],"identifier":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/sam_color_image","type":"topic","role":"symbol","fragments":[{"text":"sam_color_image","kind":"identifier"}],"title":"sam_color_image","url":"\/documentation\/dotfacelite\/sam_color_image","kind":"symbol"},"doc://DotFaceLite/documentation/DotFaceLite/samSelectDetailRegion":{"kind"