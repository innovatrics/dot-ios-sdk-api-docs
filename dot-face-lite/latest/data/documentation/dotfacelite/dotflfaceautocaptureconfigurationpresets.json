ce verification use cases.","type":"text"},{"text":" ","type":"text"},{"text":"The component operates without any visual aids or guidance for the user, with the exception of the detection layer (tracking circle).","type":"text"},{"text":" ","type":"text"},{"text":"There is no automatic triggering of the capture process.","type":"text"},{"text":" ","type":"text"},{"text":"Instead, the client is responsible for initiating the capture by explicitly calling the ","type":"text"},{"text":"requestCapture","type":"text"},{"text":" method.","type":"text"},{"text":" ","type":"text"},{"text":"This configuration provides a minimalistic approach, offering flexibility to the client in managing the capture timing and user interaction,","type":"text"},{"text":" ","type":"text"},{"text":"which is often desired in verification scenarios.","type":"text"}],"url":"\/documentation\/dotfacelite\/dotflfaceautocaptureconfigurationpresets\/simple","identifier":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/DOTFLFaceAutoCaptureConfigurationPresets\/simple","type":"topic","kind":"symbol","fragments":[{"text":"simple","kind":"identifier"}],"role":"symbol","title":"simple"},"doc://DotFaceLite/documentation/DotFaceLite/DOTFLFaceAutoCaptureConfigurationPresets":{"type":"topic","fragments":[{"kind":"identifier","text":"DOTFLFaceAutoCaptureConfigurationPresets"}],"url":"\/documentation\/dotfacelite\/dotflfaceautocaptureconfigurationpresets","abstract":[{"text":"Pre-defined sets of configurations.","type":"text"}],"identifier":"doc:\/\/DotFaceLite\/documentation\/DotFaceLite\/DOTFLFaceAutoCaptureConfigurationPresets","role":"symbol","title":"DOTFLFaceAutoCaptureConfigurationPresets","kind":"symbol"},"doc://DotFaceLite/objc(cs)NSObject":{"identifier":"doc:\/\/DotFaceLite\/objc(cs)NSObject","type":"unresolvable","title":"NSObject"},"doc://DotFaceLite/documentation/DotFaceLite":{"title":"DotFaceLite","url":"\/documentation\/dotfacelite","role":"collection","abstract":[{"text":"version: 9.4.1","type":